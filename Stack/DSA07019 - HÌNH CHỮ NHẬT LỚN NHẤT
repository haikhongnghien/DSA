#include <bits/stdc++.h>
#define FASTER ios_base::sync_with_stdio(0); cin.tie(0); cout.tie(0);
#define ll long long
#define MOD 1000000007
#define endl '\n'
using namespace std;

int t, n;
ll M[1000005];

int main() {
    FASTER;
    cin >> t;
    while(t--) {
        cin >> n;
        for(int i = 0 ; i < n ; i++) cin >> M[i];
        stack<int> st;
        vector<int> L(n + 1, -1), R(n + 1, n);
        //vi tri dau tien ben trai < M
        for(int i = 0 ; i < n ; i++) {
            while(!st.empty() && M[st.top()] >= M[i]) st.pop();
            if(!st.empty()) L[i] = st.top();
            st.push(i);
        }
        while(!st.empty()) st.pop();
        // vi tri dau tien ben phai < M
        for(int i = n - 1 ; i >= 0 ; i--) {
            while(!st.empty() && M[st.top()] >= M[i]) st.pop();
            if(!st.empty()) R[i] = st.top();
            st.push(i);
        }
        ll ans = 0;
        for(int i = 0; i < n; i++) {
            ll width = R[i] - L[i] - 1;
            ans = max(ans, M[i] * width);
        }
        cout << ans << '\n';
    }
    return 0;
}
